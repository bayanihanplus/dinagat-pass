generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAVELER
  OPERATOR_OWNER
  OPERATOR_STAFF
  LGU_USER
  ADMIN
  SUPER_ADMIN
}

enum ExperienceFamilyCode {
  BLUE_LAGOON_PANGABANGAN
  LAKE_BABABU_BASILISA_GEOSITE
  DINAGAT_ISLAND_HOPPING
  LORETO_BONSAI_FOREST_ECO
  SAN_JOSE_MYSTICAL_CULTURE
  COMMUNITY_FOOD_LOCAL_COMMERCE
  ADVENTURE_CAVE_LAGOON_ECO
  RETURN_VISITOR_CONTINUITY
}

enum ProductCategory {
  DINAGAT_PARTNER_TOUR
  DINAGAT_CURATED_EXPERIENCE_TRAIL
  BUILD_YOUR_OWN_DINAGAT_TRAIL
}

enum BookingStatus {
  DRAFT
  REQUESTED
  OPERATOR_REVIEW
  OPERATOR_ACCEPTED
  OPERATOR_REJECTED
  PAYMENT_READY
  PAYMENT_PENDING
  PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentReadinessStatus {
  NOT_READY
  REQUIRES_OPERATOR_CONFIRMATION
  READY_FOR_PAYMENT
  PAYMENT_STARTED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  REFUND_REQUIRED
  REFUNDED
}

enum QrStatus {
  NOT_ISSUED
  ISSUED
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum ScanEventStatus {
  CREATED
  VALIDATED
  REJECTED
  DUPLICATE
  MANUAL_REVIEW
}

enum VisitStampStatus {
  NOT_ELIGIBLE
  ELIGIBLE_FROM_SCAN
  ISSUED
  REVOKED
}

enum OperatorApprovalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  SUSPENDED
  REJECTED
}

enum OperatorCapabilityStatus {
  NOT_REQUESTED
  REQUESTED
  APPROVED
  SUSPENDED
  REVOKED
}

enum MarketplaceExposureStatus {
  HIDDEN
  ELIGIBLE
  EXPOSED
  CAPPED
  SUSPENDED
}

enum SiteAccessPointStatus {
  DRAFT
  ACTIVE
  PAUSED
  SUSPENDED
  ARCHIVED
}

enum SourceAttributionType {
  DIRECT
  LGU
  OPERATOR
  OTA_PARTNER
  HOTEL_DESK
  TRAVEL_AGENCY
  COMMUNITY_PARTNER
  ADMIN_CREATED
}

enum AuditActionType {
  CREATE
  UPDATE
  APPROVE
  REJECT
  SUSPEND
  REVOKE
  VALIDATE_QR
  ISSUE_STAMP
  CHANGE_PAYMENT_READINESS
  CHANGE_MARKETPLACE_EXPOSURE
  CREATE_AUTH_CREDENTIAL
  DISABLE_AUTH_CREDENTIAL
  CREATE_AUTH_SESSION
  REVOKE_AUTH_SESSION
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String?
  role        UserRole
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  travelerProfile TravelerProfile?
  operatorOwner   Operator[]       @relation("OperatorOwner")
  auditEvents     AuditEvent[]     @relation("AuditActor")
  authCredential  AuthCredential?
  authSessions    AuthSession[]
}

model TravelerProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  publicCode String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User                    @relation(fields: [userId], references: [id])
  passes         TravelerPass[]
  bookings       Booking[]
  scanEvents     ScanEvent[]
  visitStamps    VisitStamp[]
  identityClaims TravelerIdentityClaim[]
}

model TravelerPass {
  id                 String                     @id @default(cuid())
  travelerId         String
  qrStatus           QrStatus                   @default(NOT_ISSUED)
  qrPublicCode       String                     @unique
  issuedAt           DateTime?
  activatedAt        DateTime?
  expiresAt          DateTime?
  revokedAt          DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  identityStatus     TravelerPassIdentityStatus @default(DRAFT)
  identityPublicCode String?                    @unique
  identityIssuedAt   DateTime?
  identityRevokedAt  DateTime?
  identityMetadata   Json?
  qrCredentials      TravelerPassQrCredential[]
  identityClaims     TravelerIdentityClaim[]

  traveler    TravelerProfile @relation(fields: [travelerId], references: [id])
  scanEvents  ScanEvent[]
  visitStamps VisitStamp[]
  bookings    Booking[]
}

model Operator {
  id             String                 @id @default(cuid())
  ownerUserId    String
  publicCode     String                 @unique
  displayName    String
  approvalStatus OperatorApprovalStatus @default(DRAFT)
  isActive       Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  owner           User                  @relation("OperatorOwner", fields: [ownerUserId], references: [id])
  capabilities    OperatorCapability[]
  products        ExperienceProduct[]
  bookings        Booking[]
  exposureRecords MarketplaceExposure[]
}

model OperatorCapability {
  id          String                   @id @default(cuid())
  operatorId  String
  familyCode  ExperienceFamilyCode
  status      OperatorCapabilityStatus @default(NOT_REQUESTED)
  approvedAt  DateTime?
  suspendedAt DateTime?
  revokedAt   DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id])

  @@unique([operatorId, familyCode])
}

model ExperienceProduct {
  id           String               @id @default(cuid())
  operatorId   String?
  familyCode   ExperienceFamilyCode
  category     ProductCategory
  title        String
  shortSummary String
  isBookable   Boolean              @default(false)
  isPublished  Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  operator        Operator?                @relation(fields: [operatorId], references: [id])
  bookings        Booking[]
  exposureRecords MarketplaceExposure[]
  siteAccessLinks ProductSiteAccessPoint[]
}

model Booking {
  id                      String                      @id @default(cuid())
  travelerId              String
  passId                  String?
  productId               String
  operatorId              String?
  sourceAttributionId     String?
  status                  BookingStatus               @default(REQUESTED)
  paymentReadinessStatus  PaymentReadinessStatus      @default(NOT_READY)
  requestedAt             DateTime                    @default(now())
  operatorReviewedAt      DateTime?
  confirmedAt             DateTime?
  completedAt             DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  commercialStatus        TripBookingCommercialStatus @default(DRAFT)
  commercialSourceChannel TripBookingSourceChannel?
  commercialPricingMode   TripBookingPricingMode?
  commercialPaymentStatus TripBookingPaymentStatus    @default(UNPAID)
  commercialMetadata      Json?

  traveler          TravelerProfile    @relation(fields: [travelerId], references: [id])
  pass              TravelerPass?      @relation(fields: [passId], references: [id])
  product           ExperienceProduct  @relation(fields: [productId], references: [id])
  operator          Operator?          @relation(fields: [operatorId], references: [id])
  sourceAttribution SourceAttribution? @relation(fields: [sourceAttributionId], references: [id])
  visitStamps       VisitStamp[]
  scanEvents        ScanEvent[]
}

model SiteAccessPoint {
  id                 String                       @id @default(cuid())
  publicCode         String                       @unique
  name               String
  status             SiteAccessPointStatus        @default(DRAFT)
  locationLabel      String?
  actionContext      String
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  pointType          SiteAccessPointType          @default(OTHER)
  ownerType          SiteAccessOwnerType          @default(LGU)
  ownerName          String?
  municipalityId     String?
  barangayId         String?
  destinationSiteId  String?
  operatorRegistryId String?
  publicSummary      String?
  internalNotes      String?
  latitude           Decimal?                     @db.Decimal(10, 7)
  longitude          Decimal?                     @db.Decimal(10, 7)
  metadata           Json?
  municipality       Municipality?                @relation(fields: [municipalityId], references: [id])
  barangay           Barangay?                    @relation(fields: [barangayId], references: [id])
  destinationSite    DestinationSite?             @relation(fields: [destinationSiteId], references: [id])
  operatorRegistry   LocalOperatorRegistryRecord? @relation(fields: [operatorRegistryId], references: [id])
  qrDefinitions      SiteAccessQrDefinition[]
  feeRules           SiteAccessFeeRule[]

  productLinks ProductSiteAccessPoint[]
  scanEvents   ScanEvent[]
  visitStamps  VisitStamp[]
}

model ProductSiteAccessPoint {
  id                String   @id @default(cuid())
  productId         String
  siteAccessPointId String
  isRequired        Boolean  @default(false)
  createdAt         DateTime @default(now())

  product         ExperienceProduct @relation(fields: [productId], references: [id])
  siteAccessPoint SiteAccessPoint   @relation(fields: [siteAccessPointId], references: [id])

  @@unique([productId, siteAccessPointId])
}

model ScanEvent {
  id                      String              @id @default(cuid())
  travelerId              String
  passId                  String?
  bookingId               String?
  siteAccessPointId       String
  status                  ScanEventStatus     @default(CREATED)
  scannedAt               DateTime            @default(now())
  rejectionReason         String?
  metadata                Json?
  createdAt               DateTime            @default(now())
  activityProofStatus     ActivityProofStatus @default(DRAFT)
  activityProofRecordedAt DateTime?
  activityProofMetadata   Json?

  traveler        TravelerProfile @relation(fields: [travelerId], references: [id])
  pass            TravelerPass?   @relation(fields: [passId], references: [id])
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  siteAccessPoint SiteAccessPoint @relation(fields: [siteAccessPointId], references: [id])
  visitStamp      VisitStamp?
}

model VisitStamp {
  id                 String                @id @default(cuid())
  travelerId         String
  passId             String
  bookingId          String?
  scanEventId        String?               @unique
  siteAccessPointId  String
  status             VisitStampStatus      @default(NOT_ELIGIBLE)
  issuedAt           DateTime?
  revokedAt          DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  stampStatus        VisitStampProofStatus @default(DRAFT)
  sourceType         VisitStampSourceType  @default(SITE_ACCESS_SCAN)
  proofRecordedAt    DateTime?
  proofVerifiedAt    DateTime?
  proofRevokedAt     DateTime?
  proofReferenceHash String?
  proofMetadata      Json?

  traveler        TravelerProfile @relation(fields: [travelerId], references: [id])
  pass            TravelerPass    @relation(fields: [passId], references: [id])
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  scanEvent       ScanEvent?      @relation(fields: [scanEventId], references: [id])
  siteAccessPoint SiteAccessPoint @relation(fields: [siteAccessPointId], references: [id])
}

model MarketplaceExposure {
  id          String                    @id @default(cuid())
  operatorId  String
  productId   String?
  status      MarketplaceExposureStatus @default(HIDDEN)
  score       Int                       @default(0)
  reason      String?
  exposedAt   DateTime?
  cappedAt    DateTime?
  suspendedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  operator Operator           @relation(fields: [operatorId], references: [id])
  product  ExperienceProduct? @relation(fields: [productId], references: [id])
}

model SourceAttribution {
  id          String                @id @default(cuid())
  type        SourceAttributionType
  sourceCode  String?
  sourceName  String?
  externalRef String?
  createdAt   DateTime              @default(now())

  bookings Booking[]
}

model AuditEvent {
  id          String          @id @default(cuid())
  actorUserId String?
  actionType  AuditActionType
  entityType  String
  entityId    String?
  reason      String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])
}

model ExperienceFamilyRegistry {
  id          String               @id @default(cuid())
  code        ExperienceFamilyCode @unique
  title       String
  sequence    Int
  isActive    Boolean              @default(true)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model SystemRecord {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AuthCredentialStatus {
  ACTIVE
  DISABLED
  ROTATED
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model AuthCredential {
  id           String               @id @default(cuid())
  userId       String
  passwordHash String
  passwordSalt String
  status       AuthCredentialStatus @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  disabledAt   DateTime?
  rotatedAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
}

model AuthSession {
  id               String            @id @default(cuid())
  userId           String
  sessionTokenHash String            @unique
  status           AuthSessionStatus @default(ACTIVE)
  issuedAt         DateTime          @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum RegistryRecordStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum GovernanceOwnerType {
  LGU
  PROVINCIAL_TOURISM
  DOT
  COMMUNITY
  PRIVATE_PARTNER
  MIXED
}

enum DestinationSiteType {
  BEACH
  ISLAND
  PORT_TERMINAL
  MUNICIPAL_HALL
  BARANGAY_HALL
  TOURISM_OFFICE
  ACCOMMODATION
  FOOD_MERCHANT
  TRANSPORT_NODE
  CULTURE_SITE
  NATURE_SITE
  DIVE_SITE
  SURF_SITE
  TRAIL_STOP
  VIEW_DECK
  WATERFALL
  CAVE
  OTHER
}

model Municipality {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String
  provinceName        String               @default("Dinagat Islands")
  regionName          String               @default("Caraga")
  status              RegistryRecordStatus @default(DRAFT)
  governanceOwnerType GovernanceOwnerType  @default(PROVINCIAL_TOURISM)
  governanceOwnerName String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  barangays        Barangay[]
  destinationSites DestinationSite[]
  siteAccessPoints SiteAccessPoint[]

  @@index([status])
  @@index([governanceOwnerType])
}

model Barangay {
  id                  String               @id @default(cuid())
  municipalityId      String
  code                String
  name                String
  status              RegistryRecordStatus @default(DRAFT)
  governanceOwnerType GovernanceOwnerType  @default(LGU)
  governanceOwnerName String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  municipality     Municipality      @relation(fields: [municipalityId], references: [id])
  destinationSites DestinationSite[]
  siteAccessPoints SiteAccessPoint[]

  @@unique([municipalityId, code])
  @@index([municipalityId])
  @@index([status])
  @@index([governanceOwnerType])
}

model DestinationSite {
  id                  String               @id @default(cuid())
  municipalityId      String
  barangayId          String?
  code                String
  name                String
  siteType            DestinationSiteType
  status              RegistryRecordStatus @default(DRAFT)
  governanceOwnerType GovernanceOwnerType  @default(LGU)
  governanceOwnerName String?
  publicSummary       String?
  internalNotes       String?
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  municipality     Municipality      @relation(fields: [municipalityId], references: [id])
  barangay         Barangay?         @relation(fields: [barangayId], references: [id])
  siteAccessPoints SiteAccessPoint[]

  @@unique([municipalityId, code])
  @@index([municipalityId])
  @@index([barangayId])
  @@index([siteType])
  @@index([status])
  @@index([governanceOwnerType])
}

enum LocalOperatorProviderType {
  TOUR_OPERATOR
  TRANSPORT_PROVIDER
  ACCOMMODATION_PROVIDER
  FOOD_MERCHANT
  GUIDE
  COMMUNITY_ORGANIZATION
  LGU_OPERATED
  MIXED_PROVIDER
}

enum LocalOperatorVerificationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum LocalOperatorAccreditationStatus {
  NOT_PROVIDED
  PENDING_REVIEW
  DOT_ACCREDITED
  LGU_RECOGNIZED
  PROVISIONAL
  EXPIRED
  REJECTED
}

enum LocalOperatorCapabilityCategory {
  ISLAND_HOPPING
  LAND_TOUR
  WATER_ACTIVITY
  CULTURE_COMMUNITY
  FOOD_WELLNESS
  TRANSPORT_SUPPORT
  ACCOMMODATION
  GUIDE_SERVICE
  SITE_ACCESS_SUPPORT
  CUSTOM_SERVICE
}

enum LocalOperatorCommercialReadinessStatus {
  NOT_READY
  PROFILE_ONLY
  REQUEST_TO_CONFIRM
  PRICING_READY
  BOOKING_READY
  SUSPENDED
}

enum LocalOperatorExposureStatus {
  HIDDEN
  ELIGIBLE_FOR_REVIEW
  APPROVED_FOR_EXPOSURE
  SUSPENDED
  BLOCKED
}

enum LocalOperatorComplianceSeverity {
  INFO
  WARNING
  RESTRICTION
  SUSPENSION
  BLOCKER
}

model LocalOperatorRegistryRecord {
  id                        String                                 @id @default(cuid())
  registryCode              String                                 @unique
  displayName               String
  legalName                 String?
  providerType              LocalOperatorProviderType
  verificationStatus        LocalOperatorVerificationStatus        @default(DRAFT)
  accreditationStatus       LocalOperatorAccreditationStatus       @default(NOT_PROVIDED)
  commercialReadinessStatus LocalOperatorCommercialReadinessStatus @default(NOT_READY)
  exposureStatus            LocalOperatorExposureStatus            @default(HIDDEN)
  primaryMunicipalityCode   String?
  primaryBarangayCode       String?
  contactPersonName         String?
  contactEmail              String?
  contactPhone              String?
  publicSummary             String?
  internalNotes             String?
  termsAcceptedAt           DateTime?
  lastReviewedAt            DateTime?
  lastReviewedByUserId      String?
  metadata                  Json?
  createdAt                 DateTime                               @default(now())
  updatedAt                 DateTime                               @updatedAt

  capabilities      LocalOperatorCapabilityRecord[]
  complianceRecords LocalOperatorComplianceRecord[]
  siteAccessPoints  SiteAccessPoint[]

  @@index([providerType])
  @@index([verificationStatus])
  @@index([accreditationStatus])
  @@index([commercialReadinessStatus])
  @@index([exposureStatus])
  @@index([primaryMunicipalityCode])
  @@index([primaryBarangayCode])
}

model LocalOperatorCapabilityRecord {
  id                 String                          @id @default(cuid())
  operatorRegistryId String
  category           LocalOperatorCapabilityCategory
  status             RegistryRecordStatus            @default(DRAFT)
  title              String?
  description        String?
  readinessNotes     String?
  metadata           Json?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  operatorRegistry LocalOperatorRegistryRecord @relation(fields: [operatorRegistryId], references: [id])

  @@unique([operatorRegistryId, category])
  @@index([operatorRegistryId])
  @@index([category])
  @@index([status])
}

model LocalOperatorComplianceRecord {
  id                 String                          @id @default(cuid())
  operatorRegistryId String
  severity           LocalOperatorComplianceSeverity @default(INFO)
  status             RegistryRecordStatus            @default(ACTIVE)
  title              String
  details            String?
  reason             String?
  resolvedAt         DateTime?
  resolvedByUserId   String?
  metadata           Json?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  operatorRegistry LocalOperatorRegistryRecord @relation(fields: [operatorRegistryId], references: [id])

  @@index([operatorRegistryId])
  @@index([severity])
  @@index([status])
}

enum SiteAccessPointType {
  LGU_SITE
  TOURISM_SITE
  PORT_TERMINAL
  BARANGAY_ACCESS_POINT
  ACCOMMODATION_CHECK_IN
  OPERATOR_CHECK_IN
  MERCHANT_CHECK_IN
  TRANSPORT_CHECK_IN
  TRAIL_STOP
  EVENT_GATE
  OTHER
}

enum SiteAccessOwnerType {
  LGU
  PROVINCIAL_TOURISM
  DOT
  BARANGAY
  COMMUNITY
  PRIVATE_PARTNER
  LOCAL_OPERATOR
  ACCOMMODATION
  MERCHANT
  MIXED
}

enum SiteAccessQrPurpose {
  SITE_CONTEXT
  ACCESS_CHECK_IN
  PAYMENT_CONTEXT
  STAMP_VALIDATION
  ARRIVAL_LOG
  OPERATOR_SERVICE_CHECK_IN
  ACCOMMODATION_CHECK_IN
  MERCHANT_CHECK_IN
  EVENT_ENTRY
}

enum SiteAccessFeeRuleType {
  NONE
  STANDARD
  RESIDENT_RATE
  DISCOUNTED
  EXEMPT
  SENIOR_RATE
  CHILD_RATE
  CUSTOM
}

enum SiteAccessFeeCollectionMode {
  NOT_COLLECTED
  CASH_ON_SITE
  ONLINE_PREPAY
  COUNTER_PAYMENT
  PARTNER_COLLECTED
  GOVERNMENT_COLLECTED
  MIXED
}

enum SiteAccessEligibilityType {
  PUBLIC
  RESIDENT
  NON_RESIDENT
  SENIOR
  CHILD
  STUDENT
  PWD
  LGU_STAFF
  OPERATOR_STAFF
  APPROVED_PARTNER
  CUSTOM
}

model SiteAccessQrDefinition {
  id                String               @id @default(cuid())
  siteAccessPointId String
  purpose           SiteAccessQrPurpose
  status            RegistryRecordStatus @default(DRAFT)
  label             String
  qrSlug            String               @unique
  description       String?
  validFrom         DateTime?
  validUntil        DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  siteAccessPoint SiteAccessPoint @relation(fields: [siteAccessPointId], references: [id])

  @@index([siteAccessPointId])
  @@index([purpose])
  @@index([status])
}

model SiteAccessFeeRule {
  id                   String                      @id @default(cuid())
  siteAccessPointId    String
  ruleType             SiteAccessFeeRuleType
  eligibilityType      SiteAccessEligibilityType   @default(PUBLIC)
  collectionMode       SiteAccessFeeCollectionMode @default(NOT_COLLECTED)
  status               RegistryRecordStatus        @default(DRAFT)
  label                String
  amount               Decimal?                    @db.Decimal(12, 2)
  currency             String                      @default("PHP")
  requiresVerification Boolean                     @default(false)
  notes                String?
  metadata             Json?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  siteAccessPoint SiteAccessPoint @relation(fields: [siteAccessPointId], references: [id])

  @@index([siteAccessPointId])
  @@index([ruleType])
  @@index([eligibilityType])
  @@index([collectionMode])
  @@index([status])
}

enum TravelerPassIdentityStatus {
  DRAFT
  ACTIVE
  PAUSED
  REVOKED
  ARCHIVED
}

enum TravelerPassQrCredentialStatus {
  DRAFT
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
  ARCHIVED
}

enum TravelerPassQrCredentialPurpose {
  TRAVELER_IDENTITY
  SITE_ACCESS_SCAN
  BOOKING_CONTEXT
  STAFF_VALIDATION
  GOVERNANCE_AUDIT
}

enum TravelerIdentityClaimType {
  EMAIL
  PHONE
  NAME_REFERENCE
  DOCUMENT_REFERENCE
  MANUAL_GOVERNANCE_REFERENCE
  EXTERNAL_REFERENCE
}

enum TravelerIdentityClaimStatus {
  DRAFT
  CLAIMED
  VERIFIED
  REJECTED
  REVOKED
  ARCHIVED
}

model TravelerPassQrCredential {
  id             String                          @id @default(cuid())
  passId         String
  credentialCode String                          @unique
  status         TravelerPassQrCredentialStatus  @default(DRAFT)
  purpose        TravelerPassQrCredentialPurpose @default(TRAVELER_IDENTITY)
  qrTokenHash    String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  rotationReason String?
  metadata       Json?
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  pass TravelerPass @relation(fields: [passId], references: [id])

  @@index([passId])
  @@index([status])
  @@index([purpose])
  @@index([issuedAt])
  @@index([expiresAt])
}

model TravelerIdentityClaim {
  id                 String                      @id @default(cuid())
  travelerId         String
  passId             String?
  claimType          TravelerIdentityClaimType
  status             TravelerIdentityClaimStatus @default(DRAFT)
  claimReferenceHash String?
  verificationNotes  String?
  verifiedAt         DateTime?
  verifiedByUserId   String?
  revokedAt          DateTime?
  metadata           Json?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  traveler TravelerProfile @relation(fields: [travelerId], references: [id])
  pass     TravelerPass?   @relation(fields: [passId], references: [id])

  @@index([travelerId])
  @@index([passId])
  @@index([claimType])
  @@index([status])

  PENDING_REVIEW
  ACTIVE
  REVOKED
  SUPERSEDED
}

model CommercialTerms {
  id          String                @id @default(cuid())
  type        CommercialTermsType
  version     Int
  title       String
  summary     String?
  body        String
  status      TermsAcceptanceStatus @default(DRAFT)
  effectiveAt DateTime?
  retiredAt   DateTime?


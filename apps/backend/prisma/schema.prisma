model ActivityProofRecord {
  id                  String              @id @default(cuid())
  proofCode           String              @unique
  travelerId          String?
  passId              String?
  siteAccessPointId   String?
  scanEventId         String?
  visitStampId        String?
  bookingId           String?
  proofType           ActivityProofType
  status              ActivityProofStatus @default(DRAFT)
  occurredAt          DateTime?
  verifiedAt          DateTime?
  verifiedByUserId    String?
  sourceReferenceHash String?
  governanceNotes     String?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  evidence ActivityProofEvidence[]

  @@index([travelerId])
  @@index([passId])
  @@index([siteAccessPointId])
  @@index([scanEventId])
  @@index([visitStampId])
  @@index([bookingId])
  @@index([proofType])
  @@index([status])
  @@index([occurredAt])
  @@index([verifiedAt])
}

model ActivityProofEvidence {
  id                    String                    @id @default(cuid())
  proofRecordId         String
  evidenceCode          String                    @unique
  evidenceType          ActivityProofEvidenceType
  status                ActivityProofStatus       @default(DRAFT)
  evidenceReferenceHash String?
  capturedAt            DateTime?
  verifiedAt            DateTime?
  verifiedByUserId      String?
  metadata              Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  proofRecord ActivityProofRecord @relation(fields: [proofRecordId], references: [id])

  @@index([proofRecordId])
  @@index([evidenceType])
  @@index([status])
  @@index([capturedAt])
  @@index([verifiedAt])
}


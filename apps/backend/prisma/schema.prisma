  commercialTermsId     String
  operatorRegistryId    String
  acceptedByUserId      String?
  status                TermsAcceptanceStatus @default(ACTIVE)
  acceptedAt            DateTime              @default(now())
  revokedAt             DateTime?
  acceptanceSnapshotJson Json?
  sourceIp              String?
  userAgent             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([commercialTermsId, operatorRegistryId])
  @@index([commercialTermsId])
  @@index([operatorRegistryId])
  @@index([acceptedByUserId])
  @@index([status])
  @@index([acceptedAt])
}


model TripBookingCommercialRecord {
  id                         String                       @id @default(cuid())
  commercialCode             String                       @unique
  bookingId                  String?
  travelerId                 String?
  passId                     String?
  sourceChannel              TripBookingSourceChannel
  productType                TripBookingProductType
  pricingMode                TripBookingPricingMode
  commercialStatus           TripBookingCommercialStatus  @default(DRAFT)
  paymentStatus              TripBookingPaymentStatus     @default(UNPAID)
  fulfillmentStatus          TripBookingFulfillmentStatus @default(NOT_REQUIRED)
  assignedOperatorRegistryId String?
  sourcePartnerName          String?
  sourceReferenceHash        String?
  quotedAmountCents          Int?
  confirmedAmountCents       Int?
  currency                   String                       @default("PHP")
  paxCount                   Int?
  requestedForDate           DateTime?
  confirmedAt                DateTime?
  cancelledAt                DateTime?
  expiresAt                  DateTime?
  governanceNotes            String?
  metadata                   Json?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  lineItems          TripBookingLineItem[]
  fulfillmentRecords TripBookingFulfillmentRecord[]

  @@index([bookingId])
  @@index([travelerId])
  @@index([passId])
  @@index([sourceChannel])
  @@index([productType])
  @@index([pricingMode])
  @@index([commercialStatus])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([assignedOperatorRegistryId])
  @@index([requestedForDate])
  @@index([confirmedAt])
}

model TripBookingLineItem {
  id                 String                 @id @default(cuid())

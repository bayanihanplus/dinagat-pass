  quantity           Int                    @default(1)
  unitAmountCents    Int?
  totalAmountCents   Int?
  currency           String                 @default("PHP")
  governanceNotes    String?
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  commercialRecord TripBookingCommercialRecord @relation(fields: [commercialRecordId], references: [id])

  @@index([commercialRecordId])
  @@index([productType])
  @@index([pricingMode])
}

model TripBookingFulfillmentRecord {
  id                         String                       @id @default(cuid())
  commercialRecordId         String
  fulfillmentCode            String                       @unique
  fulfillmentStatus          TripBookingFulfillmentStatus @default(PENDING_ASSIGNMENT)
  assignedOperatorRegistryId String?
  assignedByUserId           String?
  acceptedAt                 DateTime?
  startedAt                  DateTime?
  completedAt                DateTime?
  cancelledAt                DateTime?
  reassignedAt               DateTime?
  fulfillmentReferenceHash   String?
  governanceNotes            String?
  metadata                   Json?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt

  commercialRecord TripBookingCommercialRecord @relation(fields: [commercialRecordId], references: [id])

  @@index([commercialRecordId])
  @@index([fulfillmentStatus])
  @@index([assignedOperatorRegistryId])
  @@index([assignedByUserId])
  @@index([acceptedAt])
  @@index([completedAt])
}

